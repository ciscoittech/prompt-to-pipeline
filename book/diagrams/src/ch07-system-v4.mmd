---
title: "v4: Automated Guard Rails"
---
flowchart TD
    INPUT["Your input"] --> CLAUDE

    subgraph CONTEXT["Loaded Into Claude"]
        CLAUDE_MD["CLAUDE.md"]
        SKILL["Skill\n(expertise)"]
        STATE_IN["State\n(history)"]
    end

    CLAUDE_MD --> CLAUDE
    SKILL -.-> CLAUDE
    STATE_IN --> CLAUDE["Claude"]

    CLAUDE --> SAVE["Claude tries to save file"]

    SAVE --> HOOK{"HOOK CHECK\n(runs automatically)"}

    HOOK -->|"PASS"| OUTPUT["Output delivered"]
    HOOK -->|"BLOCK\n(exit 2)"| FAIL["Error feedback\nto Claude"]
    FAIL -->|"Fix + retry"| CLAUDE

    OUTPUT --> STATE_OUT["State updated"]

    style INPUT fill:#f5f5f5,stroke:#333
    style CONTEXT fill:#E3F2FD,stroke:#1565C0
    style CLAUDE_MD fill:#42A5F5,stroke:#1565C0,color:#fff
    style SKILL fill:#66BB6A,stroke:#2E7D32,color:#fff
    style STATE_IN fill:#FFC107,stroke:#F9A825
    style CLAUDE fill:#7E57C2,stroke:#512DA8,color:#fff
    style SAVE fill:#E1BEE7,stroke:#7B1FA2
    style HOOK fill:#EF5350,stroke:#C62828,color:#fff,stroke-width:2px
    style OUTPUT fill:#A5D6A7,stroke:#4CAF50
    style FAIL fill:#FFCDD2,stroke:#E53935
    style STATE_OUT fill:#FFC107,stroke:#F9A825
