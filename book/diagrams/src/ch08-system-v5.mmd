---
title: "v5: Connected to the Outside World"
---
flowchart TD
    INPUT["Your input"] --> CLAUDE

    subgraph CONTEXT["Local Files (always available)"]
        CLAUDE_MD["CLAUDE.md"]
        SKILL["Skill\n(expertise)"]
        STATE_IN["State\n(history)"]
    end

    subgraph EXTERNAL["Connections (external data)"]
        WEB["Web search\n(built-in)"]
        MCP["Remote servers\n(Notion, Drive, etc.)"]
    end

    CLAUDE_MD --> CLAUDE
    SKILL -.-> CLAUDE
    STATE_IN --> CLAUDE

    WEB -->|"current info,\nsources, research"| CLAUDE["Claude"]
    MCP -->|"your data from\nother tools"| CLAUDE

    CLAUDE --> SAVE["Claude produces output"]
    SAVE --> HOOK{"HOOK CHECK"}

    HOOK -->|"PASS"| OUTPUT["Output delivered\n(using ALL sources)"]
    HOOK -->|"BLOCK"| FAIL["Fix + retry"]
    FAIL --> CLAUDE

    OUTPUT --> STATE_OUT["State updated"]

    style INPUT fill:#f5f5f5,stroke:#333
    style CONTEXT fill:#E3F2FD,stroke:#1565C0
